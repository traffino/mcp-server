{
  // Devcontainer-Sicherheitsmodell: Push aus Container ist hart geblockt (DEVCONTAINER=true + pre-push-Hook).
  // Keine Credentials im Image, kein SSH-Agent-Forwarding, keine Cred-Mounts.
  // Quelle: ~/.claude/vault/concepts/devcontainer-architektur.md
  "name": "mcp-server",

  // Major-Version gepinnt auf 1 (aktuell Go 1.25, Stand 2026-05).
  // 2026-05-13: Verfuegbarkeit pruefen mit: docker pull mcr.microsoft.com/devcontainers/go:1-bookworm
  // Fuer praeziseren Pin: mcr.microsoft.com/devcontainers/go:1.25-bookworm (Tag-Verfuegbarkeit vorab pruefen).
  // Delve (dlv) ist im Microsoft-Devcontainer-Image bereits enthalten, kein Feature noetig.
  "image": "mcr.microsoft.com/devcontainers/go:1-bookworm",

  // Sicherheitsmarker: Hook .githooks/pre-push prueft diesen Wert und blockt bei "true".
  "containerEnv": {
    "DEVCONTAINER": "true"
  },

  // Port 2345: Delve Debug-Server.
  // MCP-Server hier laeuft ueber stdio (cmd/{drawio,bunq,ms365,aggregator,brave,...}); kein klassischer
  // HTTP-Port. Nur Delve fuer Debugging. Bei spaeteren HTTP/SSE-MCP-Varianten Port ergaenzen.
  "forwardPorts": [2345],

  // Fester Container-Name (`devcontainer-<basename>`) — verbessert `docker ps`-Lesbarkeit.
  // Devcontainer-CLI handhabt Konflikte via --remove-existing-container. Unterstuetzt `./dev down`.
  "runArgs": ["--name", "devcontainer-${localWorkspaceFolderBasename}"],

  // Named Volumes: Go-Modul-Cache und Build-Cache bleiben ueber Container-Rebuilds erhalten.
  // gomodcache: /go/pkg/mod (GOPATH-basierter Standard-Pfad im Microsoft-Image).
  // gocache: /home/vscode/.cache/go-build (GOCACHE-Pfad fuer Compile-Artefakte).
  // Permissions im post-create gechownt — wichtig: das Volume-Mount auf .cache/go-build resetet
  // auch /home/vscode/.cache (Parent) auf root; das Script chownt deshalb beide.
  "mounts": [
    "source=devcontainer-${localWorkspaceFolderBasename}-gomodcache,target=/go/pkg/mod,type=volume",
    "source=devcontainer-${localWorkspaceFolderBasename}-gocache,target=/home/vscode/.cache/go-build,type=volume"
  ],

  // Volume-chown + Versions-Sanity + Push-Block-Hook. Script erlaubt sauberes Fehler-Handling.
  "postCreateCommand": ".devcontainer/post-create.sh",

  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go"
      ]
    }
  }
}
